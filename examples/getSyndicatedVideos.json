{
  "operationId": "getSyndicatedVideos",
  "method": "GET",
  "path": "/feeds/videos.{format}",
  "summary": "Common videos feeds",
  "description": "",
  "tags": [
    "Video Feeds"
  ],
  "parameters": [
    {
      "name": "format",
      "in": "path",
      "required": true,
      "description": "format expected (we focus on making `rss` the most feature-rich ; it serves [Media RSS](https://www.rssboard.org/media-rss))",
      "schema": {
        "type": "string",
        "enum": [
          "xml",
          "rss",
          "rss2",
          "atom",
          "atom1",
          "json",
          "json1"
        ]
      }
    },
    {
      "name": "accountId",
      "in": "query",
      "required": false,
      "description": "limit listing to a specific account",
      "schema": {
        "type": "string"
      }
    },
    {
      "name": "accountName",
      "in": "query",
      "required": false,
      "description": "limit listing to a specific account",
      "schema": {
        "type": "string"
      }
    },
