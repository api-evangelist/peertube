{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/peertube/main/json-schema/ActorInfo.json",
  "title": "ActorInfo",
  "properties": {
    "id": {
      "$ref": "#/components/schemas/id"
    },
    "name": {
      "type": "string"
    },
    "displayName": {
      "type": "string"
    },
    "host": {
      "type": "string",
      "format": "hostname"
    },
    "avatars": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/ActorImage"
      }
    }
  }
}